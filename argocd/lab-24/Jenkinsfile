pipeline {
    agent any

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-creds')
        GITHUB_CREDENTIALS = credentials('github-creds')
        IMAGE_NAME = "${DOCKERHUB_CREDENTIALS_USR}/ivolve-gitops-app"
        IMAGE_TAG = "${BUILD_NUMBER}"
        MANIFEST_FILE = "k8s/deployment.yaml"
        GITOPS_REPO = "https://github.com/YOUR_USER/YOUR_REPO.git"
    }

    stages {
        stage('Build App') {
            steps {
                sh './gradlew jar'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
            }
        }

        stage('Push Image to DockerHub') {
            steps {
                sh """
                    echo ${DOCKERHUB_CREDENTIALS_PSW} | docker login -u ${DOCKERHUB_CREDENTIALS_USR} --password-stdin
                    docker push ${IMAGE_NAME}:${IMAGE_TAG}
                """
            }
        }

        stage('Delete Image Locally') {
            steps {
                sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true"
            }
        }

        stage('Update deployment.yaml and Push to GitHub') {
            steps {
                sh """
                    sed -i 's|image: .*|image: ${IMAGE_NAME}:${IMAGE_TAG}|g' ${MANIFEST_FILE}
                    git config user.email "jenkins@ci.local"
                    git config user.name "Jenkins"
                    git add ${MANIFEST_FILE}
                    git commit -m "ci: update image to ${IMAGE_TAG}" || echo "No changes to commit"
                    git push https://${GITHUB_CREDENTIALS_USR}:${GITHUB_CREDENTIALS_PSW}@github.com/YOUR_USER/YOUR_REPO.git HEAD:main
                """
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "ArgoCD will sync the new image from Git."
        }
        failure {
            echo "Pipeline failed. Check the Jenkins logs."
        }
    }
}
